{
  "name": "sparkmind-sovereign",
  "type": "module",
  "version": "1.0.0",
  "description": "SparkMind Sovereign Mission Control — Trilogy execution dashboard, handoff manager, decision log, sprint tracker, prompt builder, doctrine hardener.",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=sparkmind-sovereign-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name sparkmind-sovereign",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000/api/health",
    "db:migrate:local": "wrangler d1 migrations apply sparkmind-sovereign-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply sparkmind-sovereign-production",
    "db:seed": "wrangler d1 execute sparkmind-sovereign-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute sparkmind-sovereign-production --local"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0",
    "@cloudflare/workers-types": "^4.20240614.0"
  }
}
